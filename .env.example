# Copy this file to .env and fill in your actual values
# DO NOT commit .env files to Git

# Server Configuration
PORT=5000
NODE_ENV=development
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://...
UPSTASH_REDIS_REST_URL=https://happy-terrier-89297.upstash.io
UPSTASH_REDIS_REST_TOKEN=gQAAAAAAAVzRAAIgcDI1MmFhYjNmYmY0OGM0ZDU5YThmMDJmMThiYWUyMzU1OA
SMTP_HOST=smtp.sendgrid.net
